@article{mursch2008,
  title = {Results of the {{DIVA-1 Expedition}} of {{RV}} ``{{Meteor}}'' ({{Cruise M48}}:1):{{Three}} New Species of {{Munnopsidae Sars}}, 1864 from Abyssal Depths of the {{AngolaBasin}} ({{Crustacea}}: {{Isopoda}}: {{Asellota}})},
  shorttitle = {Results of the {{DIVA-1 Expedition}} of {{RV}} ``{{Meteor}}'' ({{Cruise M48}}},
  author = {Mursch, Andre and Brenke, Nils and W{\"a}gele, Johann Wolfgang},
  year = 2008,
