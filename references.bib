@article{leat2016,
  title = {Bathymetry and Geological Setting of the {{South Sandwich Islands}} Volcanic Arc},
  author = {Leat, Philip T. and Fretwell, Peter T. and Tate, Alex J. and Larter, Robert D. and Martin, Tara J. and Smellie, John L. and Jokat, Wilfried and Bohrmann, Gerhard},
