@article{jonsson2004,
  title = {A New Path for the {{Denmark Strait}} Overflow Water from the {{Iceland Sea}} to {{Denmark Strait}}},
  author = {Jonsson, Steingrimur and Valdimarsson, Hedinn},
  year = 2004,
  month = feb,
  journal = {Geophysical Research Letters},
  volume = {31},
  number = {3},
  pages = {2003GL019214},
