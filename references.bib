@article{bober2018a,
  title = {New {{Macrostylidae}} ({{Isopoda}}) from the {{Northwest Pacific Basin}} Described by Means of Integrative Taxonomy with Reference to Geographical Barriers in the Abyss},
  author = {Bober, Simon and Riehl, Torben and Henne, Stephan and Brandt, Angelika},
  year = 2018,
  month = mar,
  journal = {Zoological Journal of the Linnean Society},
  volume = {182},
