@article{malyutina2007,
  title = {{\emph{Gurjanopsis Australis}} Gen. Nov., Sp. Nov., a New Epibenthic Deep-Sea Munnopsid ({{Crustacea}}, {{Isopoda}}, {{Munnopsidae}}) from the {{Weddell Sea}}, {{Southern Ocean}}},
  author = {Malyutina, Marina and Brandt, Angelika},
  year = 2007,
