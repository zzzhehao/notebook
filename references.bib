@article{malyutina1997,
  title = {Disconectes Vanhoeffeni Sp.n., a New Isopod Species of the Family {{Munnopsidae}} from the {{South-Sandwich Trench}} of the {{Antarctic}}},
  author = {Malyutina, Marina},
