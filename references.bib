@article{serov1995,
  title = {A Review of the {{Stenetriidae}} ({{Crustacea}}: {{Isopoda}}: {{Asellota}})},
  shorttitle = {A Review of the {{Stenetriidae}} ({{Crustacea}}},
  author = {Serov, Peter A. and Wilson, George D. F.},
  year = 1995,
  month = may,
  journal = {Records of the Australian Museum},
  volume = {47},
  number = {1},
  pages = {39--82},
  issn = {0067-1975},
  doi = {10.3853/j.0067-1975.47.1995.2},
  url = {https://journals.australian.museum/serov-and-wilson-1995-rec-aust-mus-471-3982/},
  urldate = {2025-08-15},
  abstract = {The current classification of the Stenetriidae includes five genera and 63 species, of which 57 species are contained in the genus Stenetrium Haswell, 1881. A history of the classification of the family Stenetriidae is reviewed and useful characters for defining stenetriid taxa and species are derived from the literature. A new diagnosis for the family is provided. Stenetrium is redefined and its composition reduced to 18 species. The type species of Stenetrium, S. armatum Haswell, 1881, is fully redescribed. A new species, Stenetrium adrianae, is described in this paper, highlighting morphological variation that can be useful for distinguishing stenetriid taxa. Three other named genera, Stenobermuda Schultz, 1979a (Stenetrigus Schultz, 1982 is a junior synonym), Protallocoxa Schultz, 1978, and Tenupedunculus Schultz, 1982, are redefined and their compositions adjusted. Four new genera, Tristenium, Hansenium, Liocoryphe, and Mizothenar, are erected to contain distinctive species groups not treated in the literature. Six species are poorly described and cannot be classified in this new arrangement for the family. Lists of species assigned to each group and a key to the genera are provided.},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/serov1995.pdf}
}

