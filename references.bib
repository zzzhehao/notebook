@article{imbs2021,
  title = {Current {{Progress}} in {{Lipidomics}} of {{Marine Invertebrates}}},
  author = {Imbs, Andrey B. and Ermolenko, Ekaterina V. and Grigorchuk, Valeria P. and Sikorskaya, Tatiana V. and Velansky, Peter V.},
  year = 2021,
  month = nov,
  journal = {Marine Drugs},
  volume = {19},
  number = {12},
  pages = {660},
  issn = {1660-3397},
  doi = {10.3390/md19120660},
  url = {https://www.mdpi.com/1660-3397/19/12/660},
  urldate = {2026-05-03},
  abstract = {Marine invertebrates are a paraphyletic group that comprises more than 90\% of all marine animal species. Lipids form the structural basis of cell membranes, are utilized as an energy reserve by all marine invertebrates, and are, therefore, considered important indicators of their ecology and biochemistry. The nutritional value of commercial invertebrates directly depends on their lipid composition. The lipid classes and fatty acids of marine invertebrates have been studied in detail, but data on their lipidomes (the profiles of all lipid molecules) remain very limited. To date, lipidomes or their parts are known only for a few species of mollusks, coral polyps, ascidians, jellyfish, sea anemones, sponges, sea stars, sea urchins, sea cucumbers, crabs, copepods, shrimp, and squid. This paper reviews various features of the lipid molecular species of these animals. The results of the application of the lipidomic approach in ecology, embryology, physiology, lipid biosynthesis, and in studies on the nutritional value of marine invertebrates are also discussed. The possible applications of lipidomics in the study of marine invertebrates are considered.},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/imbs2021.pdf}
}

@article{ishikawa2017,
  title = {Integrated Trophic Position Decreases in More Diverse Communities of Stream Food Webs},
  author = {Ishikawa, Naoto F. and Chikaraishi, Yoshito and Ohkouchi, Naohiko and Murakami, Aya R. and Tayasu, Ichiro and Togashi, Hiroyuki and Okano, Jun-ichi and Sakai, Yoichiro and Iwata, Tomoya and Kondoh, Michio and Okuda, Noboru},
  year = 2017,
  month = may,
  journal = {Scientific Reports},
  volume = {7},
  number = {1},
  pages = {2130},
  issn = {2045-2322},
  doi = {10.1038/s41598-017-02155-8},
  url = {https://www.nature.com/articles/s41598-017-02155-8},
  urldate = {2026-05-28},
  abstract = {Abstract             The relationship between biodiversity and ecosystem functioning is an important theme in environmental sciences. We propose a new index for configuration of the biomass pyramid in an ecosystem, named integrated trophic position (iTP). The iTP is defined as a sum of trophic positions (i.e. the average number of steps involved in biomass transfer) of all the animals in a food web integrated by their individual biomass. The observed iTP for stream macroinvertebrates ranged from 2.39 to 2.79 and was negatively correlated with the species density and the Shannon--Wiener diversity index of the local community. The results indicate a lower efficiency of biomass transfer in more diverse communities, which may be explained by the variance in edibility hypothesis and/or the trophic omnivory hypothesis. We found a negative effect of biodiversity on ecosystem functioning.},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/ishikawa2017.pdf}
}

@article{ishikawa2024,
  title = {Integrated Trophic Position as a Proxy for Food-web Complexity},
  author = {Ishikawa, Naoto F. and Takashima, Ayaka and Maruoka, Hirokazu and Kondoh, Michio},
  year = 2024,
  month = jan,
  journal = {Methods in Ecology and Evolution},
  volume = {15},
  number = {1},
  pages = {164--177},
  issn = {2041-210X, 2041-210X},
  doi = {10.1111/2041-210X.14256},
  url = {https://besjournals.onlinelibrary.wiley.com/doi/10.1111/2041-210X.14256},
  urldate = {2026-05-28},
  abstract = {Abstract                                                                There are two distinct approaches to describing the distributions of biomass and species in food webs: one to consider them as discrete trophic levels (TLs); and the other to consider them as continuous trophic positions (TPs). Bridging the gap between these two perspectives presents a nontrivial challenge in integrating biodiversity and food-web structure.                                                                          Food network unfolding (FNU) is a technique used to bridge this gap by partitioning the biomass of species into integer TLs to compute three complexity indices, namely vertical (                     D                     V                     ), horizontal (                     D                     H                     ) and range (                     D                     R                     ) diversity (                     D                     indices), through decomposition of Shannon's index                     H                     {$\prime$}. Using FNU, the food web (a network of species with unique TPs) is converted to a linear food chain (a biomass distribution at discrete TLs). This enables us to expect that the unfolded biomass within species decreases exponentially as the TL increases. Under this condition, the mean TL value in unfolded food chains is hypothesized to have an exponential relationship with the vertical diversity,                     D                     V                     . To explore this, we implemented FNU and calculated                     D                     indices for food webs publicly available at EcoBase (                     n                     \,=\,158) and calculated the integrated TP (iTP), defined as the biomass-weighted average TP of a given food web. The iTP corresponds to the mean TL in unfolded food chains and can be empirically measured through compound-specific isotope analysis of amino acids (CSIA-AA).                                                                                             Although our analysis is biased towards marine ecosystems, we revealed an exponential relationship between iTP and                     D                     V                     , suggesting that iTP can serve as a measurable proxy for                     D                     V                     . Furthermore, we found a positive correlation between the iTP observed in the total communities (total iTP) and the iTPs of partial communities consisting only of species with 2.0\,{$\leq$}\,TP\,{$<$}\,3.0 (partial iTP;                     r                     2                     \,=\,0.48), suggesting that                     D                     V                     can be predicted using partial iTP.                                                                                             Our findings suggest that the net effect of species diversity, excluding the effect of biomass (corresponding to                     H                     {$\prime$}\,-\,                     D                     V                     ), on food-web complexity can be revealed by combining CSIA-AA with biodiversity analysis (e.g. environmental DNA).                                                                           ,              要 旨                                                                食物網においてバイオマスと種の分布を記述するには2つの異なる方法がある。1つは離散的な栄養段階(trophic level: TL)を考え、もう1つは連続的な栄養位置 (trophic position: TP)を考える。これら2つの視点の間にある隔たりを橋渡すことは、生物多様性と食物網構造の統合において重要な課題である。                                                                          栄養ネットワークの解きほぐし(Food Network Unfolding: FNU)は、種のバイオマスを整数値の TLに分配し、シャノンの多様度指数                     H'                     を3つの複雑性指標(                     D                     指標)である垂直多様性(                     D                     V                     )、水平多様性(                     D                     H                     )、レンジ多様性(                     D                     R                     )に分解することで、前述の隔たりを埋めることができる手法である。FNUにより、固有のTPをもつ種のネットワークとしての食物網は、離散的なTLごとのバイオマスの分布としての食物連鎖へと変換できる。我々は、TLの増加に伴い、アンフォールドされた種のバイオマスは指数的に減少すると予測した。この条件で、アンフォールドされた食物連鎖におけるTLの平均値は、垂直多様性                     D                     V                     と指数的な関係性をもつはずである。このことを確かめるために、我々は公開データベースであるEcoBase収録の食物網データを用い、FNUを行って                     D                     指標を計算し、さらにバイオマスで加重平均されたTP(integrated TP: iTP)を計算した。iTPはTLの平均値と同一であり、アミノ酸の窒素同位体比測定(CSIA-AA)を行えば実証的にiTPを推定することができる。                                                                                             我々の解析は海洋生態系に偏ってはいるが、iTPと                     D                     V                     との間には指数関係が見られ、iTPは                     D                     V                     の測定可能な指標となることが示された。さらに、群集全体のiTPは、TPが2以上3未満の種のみからなる部分群集のiTPと正の相関(                     r                                            2                                          \,=\,0.48)を示したため、                     D                     V                     は部分群集のiTPからでも予測可能であると考えられた。                                                                                             我々の発見は、食物網の複雑性に対する種多様性のみの効果(バイオマスの効果を除いた                     H'                     \,-\,                     D                     V                     に対応)が、CSIA-AA と生物多様性解析(たとえば環境DNA)の組み合わせによって明らかにできることを示唆している。},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/ishikawa2024.pdf}
}

@article{jaaskinen2014,
  title = {Bayesian Clustering of {{DNA}} Sequences Using {{Markov}} Chains and a Stochastic Partition Model},
  author = {J{\"a}{\"a}skinen, V{\"a}in{\"o} and Parkkinen, Ville and Cheng, Lu and Corander, Jukka},
  year = 2014,
  month = jan,
  journal = {Statistical Applications in Genetics and Molecular Biology},
  volume = {13},
  number = {1},
  issn = {1544-6115, 2194-6302},
  doi = {10.1515/sagmb-2013-0031},
  url = {https://www.degruyter.com/document/doi/10.1515/sagmb-2013-0031/html},
  urldate = {2025-11-02},
  abstract = {In many biological applications it is necessary to cluster DNA sequences into groups that represent underlying organismal units, such as named species or genera. In metagenomics this grouping needs typically to be achieved on the basis of relatively short sequences which contain different types of errors, making the use of a statistical modeling approach desirable. Here we introduce a novel method for this purpose by developing a stochastic partition model that clusters Markov chains of a given order. The model is based on a Dirichlet process prior and we use conjugate priors for the Markov chain parameters which enables an analytical expression for comparing the marginal likelihoods of any two partitions. To find a good candidate for the posterior mode in the partition space, we use a hybrid computational approach which combines the EM-algorithm with a greedy search. This is demonstrated to be faster and yield highly accurate results compared to earlier suggested clustering methods for the metagenomics application. Our model is fairly generic and could also be used for clustering of other types of sequence data for which Markov chains provide a reasonable way to compress information, as illustrated by experiments on shotgun sequence type data from an Escherichia coli strain.},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/jaaskinen2014.pdf}
}

