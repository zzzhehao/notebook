}

@article{castello2004,
  title = {Isopods ({{Crustacea}}, {{Isopoda}}) from the {{Spanish}} ?{{Bentart-94}}/95? Expeditions to the {{South Shetland Islands}} (Sub-{{Antarctic}})},
  shorttitle = {Isopods ({{Crustacea}}, {{Isopoda}}) from the {{Spanish}} ?},
  author = {Castell{\'o}, Jos{\'e}},
  year = 2004,
  month = aug,
  journal = {Polar Biology},
  issn = {0722-4060, 1432-2056},
  doi = {10.1007/s00300-004-0646-9},
  url = {http://link.springer.com/10.1007/s00300-004-0646-9},
  urldate = {2025-08-05},
  abstract = {Eighty-seven samples containing isopods were studied from the Spanish programs ``Bentart 94'' and ``Bentart 95'' in the Livingston Island and nearby areas (South Shetlands, sub-Antarctic). The samples were obtained mainly using box corers (meiobenthos), an Agassiz dredge (epibenthos) and a suprabenthic sledge (suprabenthos). Seventy-eight species were found; 27 were recorded for the first time in the South Shetland Islands. Two other species (Austrosignum escandellae and Coulmannia ramosae) had previously been described as new species from the specimens of the collection ``Bentart 95''. The largest number of species were found at station number 6 (B95: 21 species). The largest populations were in sample 6TA (B95: 215 specimens of Paramunna rostrata and 99 specimens of Santia mawsoni). As regards depth, the distribution of species varied from 2 m (Ceratoserolis trilobitoides, B95: sample 5TA) to 1,019 m (Ceratoserolis meridionalis, B95: sample A31 (5 mm)). Muddy bottoms were the most common habitat. The most diverse families were Munnopsidae (11 species), Paramunnidae (9 species) and Antarcturidae (9 species). This paper adds to our taxonomic and biogeographical knowledge of the benthic communities from the South Shetland Islands.},
  copyright = {http://www.springer.com/tdm},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/castello2004.pdf}
}

