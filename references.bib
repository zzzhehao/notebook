  urldate = {2025-06-25},
  abstract = {Ten species of Haploniscidae Hansen, 1916 were sampled in Icelandic waters during expeditions in the framework of the BIOICE project. Nine of these were known from the North Atlantic Ocean, i.e. Haploniscus aduncus Lincoln, 1985, H. ampliatus Lincoln, 1985, Haploniscus angustus Lincoln, 1985, H. bicuspis (Sars, 1877), H. foresti Chardy, 1974, H. hamatus Lincoln, 1985, H. spinifer Hansen, 1916, Antennuloniscus simplex Lincoln, 1985 and Chauliodoniscus armadilloides (Hansen, 1916). All but H. bicuspis and H. angustus were restricted to the Atlantic Ocean south of the GreenlandIceland-Faeroe Ridge (GIF Ridge), while H. bicuspis occurred at considerable depth ranges both north and south of the GIF Ridge. A new species, Haploniscus astraphes n. sp., is described based on material from the Denmark Strait, North Atlantic and the Guinea Basin, South Atlantic. H. astraphes n. sp. belongs to a group of Haploniscus species closely related to the genus Antennuloniscus and shares several characters with species from that genus, especially the spine row on pleopod 1, the stout sensory seta on the carpus of pereopod 7 and characters of the antennae. H. astraphes n. sp. is characterized by a rectangular body shape, the straight frontal margin of the head and the strongly convex posterior margin of the pleotelson.},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/brokeland2017.pdf}
}

