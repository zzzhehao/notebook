@article{brokeland2017,
  title = {Distribution of Haploniscids ({{Isopoda}}, {{Asellota}}, {{Haploniscidae}}) in {{Icelandic}} Waters, with Description of {{{\emph{Haploniscus}}}}{\emph{ Astraphes}} n. Sp. from the {{Iceland}} Basin and the {{Southeast Atlantic Ocean}}},
  author = {Br{\"o}keland, Wiebke and Svavarsson, J{\"o}rundur},
