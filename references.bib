@article{rogers2023,
  title = {Accelerating Ocean Species Discovery and Laying the Foundations for the Future of Marine Biodiversity Research and Monitoring},
  author = {Rogers, Alex David and {Appiah-Madson}, Hannah and Ardron, Jeff A. and Bax, Nicholas J. and Bhadury, Punyasloke and Brandt, Angelika and Buttigieg, Pier-Luigi and De Clerck, Olivier and Delgado, Claudia and Distel, Daniel L. and Glover, Adrian and Gobin, Judith and Guilhon, Maila and Hampton, Shannon and {Harden-Davies}, Harriet and Hebert, Paul and Hynes, Lisa and Lowe, Miranda and MacIntyre, Sandy and Madduppa, Hawis and Mazzuco, Ana Carolina De Azevedo and McCallum, Anna and McOwen, Chris and Nattkemper, Tim Wilhelm and Odido, Mika and O'Hara, Tim and Osborn, Karen and Pouponneau, Angelique and Provoost, Pieter and Rabone, Muriel and {Ramirez-Llodra}, Eva and Scott, Lucy and Sink, Kerry Jennifer and Turk, Daniela and Watanabe, Hiromi Kayama and Weatherdon, Lauren V. and Wernberg, Thomas and Williams, Suzanne and Woodall, Lucy and Wright, Dawn J. and Zeppilli, Daniela and Steeds, Oliver},
  year = 2023,
  month = sep,
  journal = {Frontiers in Marine Science},
  volume = {10},
  pages = {1224471},
  issn = {2296-7745},
  doi = {10.3389/fmars.2023.1224471},
  url = {https://www.frontiersin.org/articles/10.3389/fmars.2023.1224471/full},
  urldate = {2024-12-29},
  abstract = {Ocean Census is a new Large-Scale Strategic Science Mission aimed at accelerating the discovery and description of marine species. This mission addresses the knowledge gap of the diversity and distribution of marine life whereby of an estimated 1 million to 2 million species of marine life between 75\% to 90\% remain undescribed to date. Without improved knowledge of marine biodiversity, tackling the decline and eventual extinction of many marine species will not be possible. The marine biota has evolved over 4 billion years and includes many branches of the tree of life that do not exist on land or in freshwater. Understanding what is in the ocean and where it lives is fundamental science, which is required to understand how the ocean works, the direct and indirect benefits it provides to society and how human impacts can be reduced and managed to ensure marine ecosystems remain healthy. We describe a strategy to accelerate the rate of ocean species discovery by: 1) employing consistent standards for digitisation of species data to broaden access to biodiversity knowledge and enabling cybertaxonomy; 2) establishing new working practices and adopting advanced technologies to accelerate taxonomy; 3) building the capacity of stakeholders to undertake taxonomic and biodiversity research and capacity development, especially targeted at low- and middle-income countries (LMICs) so they can better assess and manage life in their waters and contribute to global biodiversity knowledge; and 4) increasing observational coverage on dedicated expeditions. Ocean Census, is conceived as a global open network of scientists anchored by Biodiversity Centres in developed countries and LMICs. Through a collaborative approach, including co-production of science with LMICs, and by working with funding partners, Ocean Census will focus and grow current efforts to discover ocean life globally, and permanently transform our ability to document, describe and safeguard marine species.},
  langid = {english},
  keywords = {Org/OceanCensus,Taxonomy/IntegrativeTaxonomy,Taxonomy/SpeciesDescription,Taxonomy/SpeciesDiscovery},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/rogers2023.pdf}
}

@article{rohlfing2024,
  title = {Evidence for Feminized Genetic Males in a Flea Beetle Using Newly Identified {{X}}-linked Markers},
  author = {Rohlfing, Kim and Grewoldt, Malte and Cordellier, Mathilde and Dobler, Susanne},
  year = 2024,
  month = aug,
  journal = {Ecology and Evolution},
  volume = {14},
  number = {8},
  pages = {e70123},
  issn = {2045-7758, 2045-7758},
  doi = {10.1002/ece3.70123},
  url = {https://onlinelibrary.wiley.com/doi/10.1002/ece3.70123},
  urldate = {2025-01-13},
  abstract = {Abstract                            The equilibrium of sex ratios in sexually reproducing species is often disrupted by various environmental and genetic factors, including endosymbionts like               Wolbachia               . In this study, we explore the highly female-biased sex ratio observed in the flea beetle,               Altica lythri               , and its underlying mechanisms. Ancient hybridization events between               Altica               species have led to mitochondrial DNA introgression, resulting in distinct mitochondrial haplotypes that go along with different               Wolbachia               infections (HT1-wLytA1, HT1*- uninfected, HT2-wLytA2, and HT3-wLytB). Notably, beetles with some haplotypes exclusively produce female offspring, suggesting potential               Wolbachia               -induced phenomena such as feminization of genetic males. However, the observed female bias could also be a consequence of the ancient hybridization resulting in nuclear--cytoplasmic conflicts between introgressed mtDNA and nuclear genes. Through transcriptomic analysis and the program SEX-DETector, we established markers for genotypic sex differentiation for               A. lythri               , enabling genetic sexing via qPCR. Our findings suggest that feminization of genetic males is contributing to the skewed sex ratios, highlighting the intricate dynamics of sex determination and reproductive strategies in this flea beetle. This study provides valuable insights into the dynamics of genetic conflicts, endosymbionts, and sex ratios, revealing the novel phenomenon of genetic male feminization in the flea beetle               A. lythri               .},
  langid = {english},
  file = {/Users/hu_zhehao/Desktop/zzzhehao/90-99 Resources/90 References/Zotero File Storage/rohlfing2024.pdf}
}

